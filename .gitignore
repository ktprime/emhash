# Binary executables (no extension) - use pattern matching
# Ignore compiled binaries in bench/ and tests/ directories
bench/*
!bench/*/
!bench/*.cpp
!bench/*.cc
!bench/*.h
!bench/*.hpp
!bench/*.md
!bench/Makefile
!bench/.gitignore
tests/*
!tests/*/
!tests/*.cpp
!tests/*.h
!tests/*.md
!tests/CMakeLists.txt
!tests/Makefile
!tests/.gitignore
# Note: fuzz/test source files (tests/fuzz/*.cpp) are tracked - do NOT ignore them
tests/fuzz/fuzz_*
tests/fuzz/reproduce_bug
tests/crash-*
tests/verify/bin/

