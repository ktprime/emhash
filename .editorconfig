root = true

[*.{hpp,cpp,h,cc,c}]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

[*.{ps1,psm1}]
indent_style = space
indent_size = 4
end_of_line = crlf

[Makefile]
indent_style = tab
